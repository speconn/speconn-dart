FROM dhi.io/dart:3-alpine3.22-dev AS builder
WORKDIR /app
RUN apk add --no-cache git
COPY pubspec.yaml ./
RUN --mount=type=cache,target=/root/.pub-cache \
    dart pub get
COPY lib/ lib/
RUN --mount=type=cache,target=/root/.pub-cache \
    dart analyze lib/

FROM scratch
COPY --from=builder /app/lib/ /out/
